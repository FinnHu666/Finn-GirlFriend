<view class="page">
  <view class="header">
    <view>
      <view class="title">菜单管理</view>
      <view class="subtitle">男友维护菜品和隐藏惊喜。</view>
    </view>
  </view>

  <view class="admin-form card">
    <view class="form-title">新增菜品</view>
    <input class="input" placeholder="菜名，比如：红烧肉" value="{{form.name}}" data-field="name" bindinput="onFormInput" />
    <input class="input" placeholder="Emoji，比如：🍖" value="{{form.emoji}}" data-field="emoji" bindinput="onFormInput" />
    <textarea class="textarea" placeholder="菜品描述" value="{{form.description}}" data-field="description" bindinput="onFormInput" />
    <view class="option-row">
      <view wx:for="{{categoriesWithoutAll}}" wx:key="id" class="option {{form.category === item.id ? 'active' : ''}}" bindtap="chooseCategory" data-id="{{item.id}}">{{item.name}}</view>
    </view>
    <button class="primary-btn" bindtap="createDish">新增到菜单</button>
  </view>

  <view class="section-title">
    <text>菜品列表</text>
    <button class="ghost-btn" bindtap="loadData">刷新</button>
  </view>

  <view class="manage-list">
    <view wx:for="{{dishes}}" wx:key="id" class="manage-card card">
      <view class="manage-main">
        <view class="manage-title">{{item.emoji}} {{item.name}}</view>
        <view class="manage-meta">分类：{{item.categoryName}}｜标签：{{item.tagsText}}</view>
        <view class="manage-meta">推荐：{{item.recommended ? '是' : '否'}}｜隐藏：{{item.hidden ? '是' : '否'}}｜状态：{{item.available ? '上架' : '下架'}}</view>
      </view>
      <view class="manage-actions">
        <button bindtap="toggleRecommend" data-id="{{item.id}}" data-value="{{item.recommended}}">{{item.recommended ? '取消推荐' : '推荐'}}</button>
        <button bindtap="toggleHidden" data-id="{{item.id}}" data-value="{{item.hidden}}">{{item.hidden ? '取消隐藏' : '隐藏'}}</button>
        <button bindtap="toggleAvailable" data-id="{{item.id}}" data-value="{{item.available}}">{{item.available ? '下架' : '恢复'}}</button>
      </view>
    </view>
  </view>
</view>
