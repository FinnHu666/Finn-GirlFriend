.profile-card {
  padding: 38rpx 28rpx;
  text-align: center;
}

.avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 138rpx;
  height: 138rpx;
  margin: 0 auto 22rpx;
  border-radius: 42rpx;
  background: linear-gradient(135deg, #ffe5ea, #fff4c7);
  font-size: 72rpx;
}

.profile-name {
  font-size: 38rpx;
  font-weight: 900;
}

.profile-role {
  margin-top: 8rpx;
  color: #92736c;
  font-size: 26rpx;
}

.action-grid {
  display: grid;
  gap: 18rpx;
  margin-top: 22rpx;
}

.menu-list {
  margin-top: 22rpx;
  overflow: hidden;
}

.menu-item {
  display: grid;
  grid-template-columns: 72rpx 1fr;
  gap: 18rpx;
  width: 100%;
  padding: 26rpx;
  border-bottom: 1rpx solid rgba(255, 127, 154, 0.12);
  color: #3d2b28;
  text-align: left;
}

.menu-item:last-child {
  border-bottom: 0;
}

.menu-item text {
  font-size: 44rpx;
}

.menu-item view view:first-child {
  font-size: 29rpx;
  font-weight: 900;
}

.menu-item view view:last-child {
  margin-top: 6rpx;
  color: #92736c;
  font-size: 24rpx;
}

.orders {
  margin-top: 22rpx;
  padding: 24rpx;
}

.orders-title {
  margin-bottom: 16rpx;
  font-size: 31rpx;
  font-weight: 900;
}

.order-row {
  padding: 16rpx 0;
  border-top: 1rpx solid rgba(255, 127, 154, 0.12);
}

.order-row view {
  font-size: 27rpx;
  font-weight: 900;
}

.order-row text {
  display: block;
  margin-top: 6rpx;
  color: #92736c;
  font-size: 24rpx;
  line-height: 1.5;
}
