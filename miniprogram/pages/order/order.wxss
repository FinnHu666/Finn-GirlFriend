.plus {
  width: 74rpx;
  height: 74rpx;
  border-radius: 22rpx;
  color: #b5526b;
  background: #ffe9ee;
  font-size: 42rpx;
  font-weight: 900;
}

.order-list {
  display: grid;
  gap: 18rpx;
}

.order-card {
  padding: 22rpx;
}

.order-head {
  display: flex;
  gap: 18rpx;
  align-items: center;
}

.emoji {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 92rpx;
  height: 92rpx;
  border-radius: 24rpx;
  background: #fff0d1;
  font-size: 48rpx;
}

.order-info {
  flex: 1;
  min-width: 0;
}

.name {
  font-size: 31rpx;
  font-weight: 900;
}

.meta {
  margin-top: 8rpx;
  color: #92736c;
  font-size: 24rpx;
  line-height: 1.5;
}

.order-actions {
  display: flex;
  justify-content: flex-end;
  gap: 14rpx;
  margin-top: 18rpx;
}

.order-actions button {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  color: #b5526b;
  background: #fff0f4;
  font-size: 24rpx;
  font-weight: 800;
}

.empty .primary-btn {
  margin-top: 28rpx;
}

.submit-panel {
  margin-top: 22rpx;
  padding: 28rpx;
  background: linear-gradient(135deg, rgba(255, 229, 234, 0.95), rgba(255, 244, 199, 0.92));
}

.form-title {
  margin: 22rpx 0 14rpx;
  font-size: 30rpx;
  font-weight: 900;
}

.form-title:first-child {
  margin-top: 0;
}

.option-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.option {
  padding: 14rpx 22rpx;
  border: 1rpx solid rgba(255, 127, 154, 0.18);
  border-radius: 999rpx;
  color: #92736c;
  background: #fff;
  font-size: 25rpx;
  font-weight: 800;
}

.option.active {
  border-color: transparent;
  color: #fff;
  background: #ff7f9a;
}

.estimate {
  margin: 24rpx 0 18rpx;
  color: #b5526b;
  font-size: 27rpx;
  font-weight: 900;
}
