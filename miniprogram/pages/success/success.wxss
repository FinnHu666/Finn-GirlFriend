.success-page {
  display: flex;
  align-items: center;
  justify-content: center;
}

.success-card {
  width: 100%;
  padding: 46rpx 30rpx;
  text-align: center;
}

.success-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 156rpx;
  height: 156rpx;
  margin: 0 auto 28rpx;
  border-radius: 46rpx;
  color: #fff;
  background: linear-gradient(135deg, #ff7f9a, #ffd36e);
  box-shadow: 0 18rpx 34rpx rgba(255, 127, 154, 0.32);
  font-size: 76rpx;
}

.success-title {
  font-size: 44rpx;
  font-weight: 900;
}

.success-copy {
  margin: 16rpx 0 28rpx;
  color: #92736c;
  font-size: 27rpx;
  line-height: 1.7;
}

.receipt {
  margin-bottom: 24rpx;
  padding: 24rpx;
  border-radius: 22rpx;
  color: #92736c;
  background: #fff7f4;
  text-align: left;
  font-size: 26rpx;
  line-height: 1.8;
}

.receipt-title {
  color: #3d2b28;
  font-size: 30rpx;
  font-weight: 900;
}

.receipt-line {
  margin-top: 14rpx;
}

.reply {
  margin-top: 14rpx;
  color: #b5526b;
}

.secondary-btn {
  margin-top: 16rpx;
}
