.detail-card {
  overflow: hidden;
}

.detail-art {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 430rpx;
  background: linear-gradient(135deg, #ffe5ea, #fff1b8 62%, #e5f8ef);
  font-size: 148rpx;
}

.detail-body {
  padding: 30rpx;
}

.detail-name {
  font-size: 42rpx;
  font-weight: 900;
}

.detail-desc {
  margin-top: 14rpx;
  color: #92736c;
  font-size: 27rpx;
  line-height: 1.7;
}

.stat-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 22rpx;
}

.stat-grid view {
  padding: 18rpx 8rpx;
  border-radius: 18rpx;
  background: #fff7f4;
  text-align: center;
}

.stat-grid text:first-child {
  display: block;
  font-size: 25rpx;
  font-weight: 900;
}

.stat-grid text:last-child {
  display: block;
  margin-top: 6rpx;
  color: #92736c;
  font-size: 21rpx;
}

.form {
  margin-top: 22rpx;
  padding: 28rpx;
}

.form-title {
  margin: 18rpx 0 14rpx;
  font-size: 30rpx;
  font-weight: 900;
}

.form-title:first-child {
  margin-top: 0;
}

.option-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.option {
  padding: 14rpx 22rpx;
  border: 1rpx solid rgba(255, 127, 154, 0.18);
  border-radius: 999rpx;
  color: #92736c;
  background: #fff;
  font-size: 25rpx;
  font-weight: 800;
}

.option.active {
  border-color: transparent;
  color: #fff;
  background: #ff7f9a;
}

.reason {
  margin: 22rpx 0;
  padding: 20rpx;
  border-radius: 18rpx;
  color: #b5526b;
  background: #fff0f4;
  font-size: 25rpx;
  line-height: 1.6;
}
